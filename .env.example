# =============================================================================
# AnatoLearn Admin + API — Environment Variables
# Copy this file to `.env.local`.
# Never commit `.env.local`.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="AnatoLearn Admin"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="/api/v1"

# Browser CORS is intentionally not enabled. Mobile clients authenticate with bearer tokens.

# -----------------------------------------------------------------------------
# PostgreSQL / Prisma
# -----------------------------------------------------------------------------
# Runtime pooled connection from Supabase/Supavisor.
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct or session-mode connection used by Prisma Migrate.
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST:5432/postgres"

# -----------------------------------------------------------------------------
# Supabase public configuration
# These values are safe for browser use, but database/storage policies still
# must be correctly configured.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"

# -----------------------------------------------------------------------------
# Supabase server-only configuration
# NEVER expose this key in client code or use NEXT_PUBLIC_.
# -----------------------------------------------------------------------------
SUPABASE_SECRET_KEY="YOUR_SUPABASE_SECRET_KEY"

# Authentication redirects. Add the production URL in Supabase Auth settings.
SUPABASE_AUTH_REDIRECT_URL="http://localhost:3000/auth/callback"
SUPABASE_PASSWORD_RESET_REDIRECT_URL="http://localhost:3000/auth/callback?next=%2Freset-password"

# -----------------------------------------------------------------------------
# Supabase Storage
# -----------------------------------------------------------------------------
SUPABASE_STORAGE_BUCKET="anatomy-media"
SUPABASE_STORAGE_MAX_FILE_MB="8"
SUPABASE_STORAGE_ALLOWED_MIME_TYPES="image/png,image/jpeg,image/webp"

# Use "public" only when educational media should be publicly readable.
# Prefer "private" if signed URLs will be implemented.
SUPABASE_STORAGE_VISIBILITY="private"

# -----------------------------------------------------------------------------
# One-time admin bootstrap
# Use only with the explicit bootstrap script. Rotate/remove password after use.
# -----------------------------------------------------------------------------
ADMIN_BOOTSTRAP_EMAIL="admin@example.com"
ADMIN_BOOTSTRAP_PASSWORD="CHANGE_ME_USE_A_STRONG_TEMPORARY_PASSWORD"

# -----------------------------------------------------------------------------
# Cron / scheduled jobs
# Use at least 32 random characters in production.
# -----------------------------------------------------------------------------
CRON_SECRET="CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARS"

# -----------------------------------------------------------------------------
# Notification provider — optional until the Expo app is connected
# -----------------------------------------------------------------------------
EXPO_ACCESS_TOKEN=""
EXPO_PUSH_ENABLED="false"

# -----------------------------------------------------------------------------
# Transactional email — optional
# Supabase Auth can send auth emails. Use this only for custom application mail.
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="AnatoLearn <noreply@example.com>"

# -----------------------------------------------------------------------------
# Error monitoring — optional
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# -----------------------------------------------------------------------------
# Distributed serverless rate limiting using Upstash Redis.
# Both values are required in production and must be configured together.
# Leave both blank only in development/test to use the in-memory fallback.
# -----------------------------------------------------------------------------
# Vercel's Upstash integration injects these automatically. A complete pair is
# required in production. Self-managed Upstash may use the legacy pair below.
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# Logging and feature flags
# -----------------------------------------------------------------------------
LOG_LEVEL="info"
NEXT_PUBLIC_ENABLE_DEMO_DATA="false"
NEXT_PUBLIC_ENABLE_NOTIFICATION_SENDING="false"
